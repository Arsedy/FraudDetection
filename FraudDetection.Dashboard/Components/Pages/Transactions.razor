@page "/transactions"
@rendermode InteractiveServer
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Navigation
@inject IJSRuntime JS

<div class="page-header animate-in">
    <h1>Transaction Log</h1>
    <p>View transaction stream and inspect suspicious activities</p>
</div>

@if (!string.IsNullOrEmpty(Pan))
{
    <div class="glass-card animate-in" style="margin-bottom: 20px; border-color: var(--accent-primary);">
        <div style="display: flex; justify-content: space-between; align-items: center;">
            <div>
                <span style="color: var(--text-muted); font-size: 0.8rem; text-transform: uppercase;">Filtered Card History</span>
                <h3 style="font-family: monospace; color: var(--accent-primary-light); margin-top: 4px;">@MaskPan(Pan)</h3>
            </div>
            <button class="btn btn-ghost btn-sm" @onclick="ClearCardFilter">Clear Filter ✖</button>
        </div>
    </div>
}

<!-- Filter Bar -->
<div class="filter-bar animate-in">
    <input class="filter-input" type="text" placeholder="Search PAN..."
           @bind="panFilter" style="width: 220px;" />

    <select class="filter-select" @bind="responseCodeFilter">
        <option value="">All Response Codes</option>
        <option value="00">00 - Approved</option>
        <option value="05">05 - Do Not Honor (Declined)</option>
        <option value="51">51 - Insufficient Funds</option>
        <option value="54">54 - Expired Card</option>
    </select>

    <button class="btn btn-primary btn-sm" @onclick="ApplyFilters">
        🔍 Search
    </button>
</div>

@if (loading)
{
    <div class="loading-container">
        <div class="loading-spinner"></div>
        <span class="loading-text">Loading transactions...</span>
    </div>
}
else if (errorMessage != null)
{
    <div class="glass-card" style="border-color: var(--accent-danger); text-align: center; padding: 40px;">
        <p style="color: var(--accent-danger-light);">⚠️ @errorMessage</p>
        <p style="color: var(--text-muted); font-size: 0.8rem; margin-top: 8px;">Ensure WebAPI is running on port 5001</p>
    </div>
}
else
{
    <div class="glass-card animate-in">
        <div class="data-table-wrapper">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Date & Time</th>
                        <th>Card (PAN)</th>
                        <th>Amount</th>
                        <th>Merchant Location</th>
                        <th>Country</th>
                        <th>Response</th>
                        <th>Flagged Rule / Detection</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (transactions.Count == 0)
                    {
                        <tr>
                            <td colspan="8" style="text-align: center; padding: 40px; color: var(--text-muted);">
                                No transactions found matching filters
                            </td>
                        </tr>
                    }
                    @foreach (var txn in transactions)
                    {
                        bool isTargetHighlight = HighlightTxnId.HasValue && txn.TransactionId == HighlightTxnId.Value;
                        string rowClass = isTargetHighlight ? "row-target-highlight" : (txn.IsFlagged ? "row-flagged" : "");

                        <tr class="@rowClass">
                            <td>
                                <span>@txn.TxnDateTime.ToString("yyyy-MM-dd HH:mm:ss")</span>
                                @if (isTargetHighlight)
                                {
                                    <span class="pulse-badge">TARGET</span>
                                }
                            </td>
                            <td>
                                <span class="pan-masked">@MaskPan(txn.PAN)</span>
                            </td>
                            <td style="font-weight: 700; color: var(--text-primary);">
                                @txn.Amount.ToString("C2")
                            </td>
                            <td>@(string.IsNullOrWhiteSpace(txn.MerchantLocation) ? "—" : txn.MerchantLocation.Trim())</td>
                            <td>@(string.IsNullOrWhiteSpace(txn.Country) ? "—" : txn.Country.Trim())</td>
                            <td>
                                @if (txn.ResponseCode == "00")
                                {
                                    <span class="badge badge-success">00 Approved</span>
                                }
                                else
                                {
                                    <span class="badge badge-danger">@txn.ResponseCode Declined</span>
                                }
                            </td>
                            <td>
                                @if (txn.IsFlagged || isTargetHighlight)
                                {
                                    <span class="badge @GetBadgeStyle(txn.TriggeredRuleId)">
                                        🚨 @(string.IsNullOrEmpty(txn.TriggeredRuleName) ? "Rule Violation Triggered" : txn.TriggeredRuleName)
                                    </span>
                                }
                                else
                                {
                                    <span style="color: var(--text-muted); font-size: 0.75rem;">—</span>
                                }
                            </td>
                            <td>
                                <div style="display: flex; gap: 6px;">
                                    <a href="model?txnId=@txn.TransactionId" class="btn btn-primary btn-sm" title="Score with ML Model">
                                        🧠 Score
                                    </a>
                                    <button class="btn btn-ghost btn-sm" title="Copy transaction JSON"
                                            @onclick="() => CopyTransaction(txn)">
                                        📋 Copy
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        @if (totalPages > 1)
        {
            <div class="pagination">
                <button class="pagination-btn" disabled="@(currentPage <= 1)" @onclick="PrevPage">← Prev</button>
                <span class="pagination-info">Page @currentPage of @totalPages (@totalCount transactions)</span>
                <button class="pagination-btn" disabled="@(currentPage >= totalPages)" @onclick="NextPage">Next →</button>
            </div>
        }
    </div>
}

@code {
    [Parameter]
    [SupplyParameterFromQuery(Name = "pan")]
    public string? Pan { get; set; }

    [Parameter]
    [SupplyParameterFromQuery(Name = "highlight")]
    public Guid? HighlightTxnId { get; set; }

    private List<TransactionItem> transactions = new();
    private bool loading = true;
    private string? errorMessage;
    private string panFilter = "";
    private string responseCodeFilter = "";
    private int currentPage = 1;
    private int totalPages = 1;
    private int totalCount = 0;

    protected override async Task OnParametersSetAsync()
    {
        panFilter = Pan ?? "";
        await LoadTransactions();
    }

    private async Task ApplyFilters()
    {
        currentPage = 1;
        await LoadTransactions();
    }

    private void ClearCardFilter()
    {
        Pan = null;
        panFilter = "";
        HighlightTxnId = null;
        Navigation.NavigateTo("/transactions");
    }

    private async Task LoadTransactions()
    {
        loading = true;
        errorMessage = null;
        try
        {
            var client = HttpClientFactory.CreateClient("FraudAPI");
            var queryParams = new List<string> { $"page={currentPage}", "pageSize=25" };

            if (!string.IsNullOrWhiteSpace(panFilter))
                queryParams.Add($"pan={Uri.EscapeDataString(panFilter)}");
            if (!string.IsNullOrWhiteSpace(responseCodeFilter))
                queryParams.Add($"responseCode={Uri.EscapeDataString(responseCodeFilter)}");

            string url = $"api/transactions?{string.Join("&", queryParams)}";
            var response = await client.GetFromJsonAsync<TransactionsResponse>(url);

            if (response != null)
            {
                transactions = response.Data;
                totalCount = response.TotalCount;
                totalPages = response.TotalPages;
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            loading = false;
        }
    }

    private async Task PrevPage()
    {
        if (currentPage > 1)
        {
            currentPage--;
            await LoadTransactions();
        }
    }

    private async Task NextPage()
    {
        if (currentPage < totalPages)
        {
            currentPage++;
            await LoadTransactions();
        }
    }

    private string MaskPan(string pan)
    {
        if (string.IsNullOrEmpty(pan) || pan.Length < 8) return pan;
        return $"{pan[..4]} •••• •••• {pan[^4..]}";
    }

    private async Task CopyTransaction(TransactionItem txn)
    {
        var json = System.Text.Json.JsonSerializer.Serialize(new
        {
            TransactionId = txn.TransactionId,
            PAN = txn.PAN,
            Amount = txn.Amount,
            TxnDateTime = txn.TxnDateTime,
            MCC = txn.MCC,
            Country = txn.Country,
            POSEntryMode = txn.POSEntryMode,
            ResponseCode = txn.ResponseCode,
            MerchantLocation = txn.MerchantLocation,
            Currency = txn.Currency
        }, new System.Text.Json.JsonSerializerOptions { WriteIndented = true });

        await JS.InvokeVoidAsync("navigator.clipboard.writeText", json);
    }

    private string GetBadgeStyle(string? ruleId)
    {
        return ruleId switch
        {
            "ML_HighConfidenceFraud" => "badge-danger",
            "VelocityRule" => "badge-warning",
            "TravelRule" => "badge-info",
            "CardTestingRule" => "badge-danger",
            "SpikeRule" => "badge-warning",
            _ => "badge-danger"
        };
    }

    private class TransactionsResponse
    {
        public int TotalCount { get; set; }
        public int Page { get; set; }
        public int PageSize { get; set; }
        public int TotalPages { get; set; }
        public List<TransactionItem> Data { get; set; } = new();
    }

    private class TransactionItem
    {
        public Guid TransactionId { get; set; }
        public string PAN { get; set; } = "";
        public decimal Amount { get; set; }
        public DateTime TxnDateTime { get; set; }
        public string MCC { get; set; } = "";
        public string Country { get; set; } = "";
        public string POSEntryMode { get; set; } = "";
        public string ResponseCode { get; set; } = "";
        public string MerchantLocation { get; set; } = "";
        public string Currency { get; set; } = "";
        public bool IsFlagged { get; set; }
        public string? TriggeredRuleId { get; set; }
        public string? TriggeredRuleName { get; set; }
        public int AlertScore { get; set; }
    }
}
